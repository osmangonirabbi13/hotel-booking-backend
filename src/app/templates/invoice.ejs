<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - HotelBook</title>
    <style>
        :root {
            --primary-color: #2563eb;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --border-color: #e2e8f0;
            --success-bg: #f0fdf4;
            --success-text: #166534;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            line-height: 1.5;
            padding: 40px 20px;
        }

        .invoice-wrapper {
            max-width: 850px;
            margin: 0 auto;
            background: var(--bg-card);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        .header-stripe {
            height: 6px;
            background: var(--primary-color);
        }

        .invoice-body {
            padding: 50px;
        }

        /* Top Section */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
        }

        .brand h1 {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .brand span {
            color: var(--primary-color);
        }

        .status-badge {
            background: var(--success-bg);
            color: var(--success-text);
            padding: 6px 12px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: 1px solid #bbf7d0;
        }

        /* Info Grid */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 1px solid var(--border-color);
        }

        .label {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 8px;
            display: block;
        }

        .value {
            font-size: 15px;
            font-weight: 600;
        }

        /* Summary Box */
        .stay-summary {
            background: #f1f5f9;
            border-radius: 12px;
            padding: 20px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 40px;
        }

        /* Table */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        th {
            text-align: left;
            padding: 12px 0;
            border-bottom: 2px solid var(--text-main);
            font-size: 13px;
            font-weight: 700;
        }

        td {
            padding: 20px 0;
            border-bottom: 1px solid var(--border-color);
            font-size: 14px;
        }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* Totals */
        .totals-container {
            display: flex;
            justify-content: flex-end;
        }

        .totals-table {
            width: 280px;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
        }

        .total-row.grand-total {
            margin-top: 15px;
            padding-top: 15px;
            border-top: 2px solid var(--primary-color);
            font-size: 20px;
            font-weight: 800;
            color: var(--primary-color);
        }

        /* Footer */
        .footer {
            margin-top: 60px;
            text-align: center;
            font-size: 12px;
            color: var(--text-muted);
        }

        @media print {
            body { background: white; padding: 0; }
            .invoice-wrapper { box-shadow: none; border: 1px solid #eee; }
        }

        @media (max-width: 600px) {
            .info-grid, .stay-summary { grid-template-columns: 1fr; }
            .invoice-body { padding: 25px; }
        }
    </style>
</head>
<body>

<div class="invoice-wrapper">
    <div class="header-stripe"></div>
    <div class="invoice-body">
        
        <div class="top-bar">
            <div class="brand">
                <h1>Hotel<span>Book</span></h1>
                <p style="color: var(--text-muted); font-size: 13px;">Official Invoice</p>
            </div>
            <div style="text-align: right;">
                <div class="status-badge">Paid in Full</div>
                <p style="font-weight: 700; margin-top: 10px;">#<%= bookingId %></p>
            </div>
        </div>

        <div class="info-grid">
            <div>
                <span class="label">Billed To</span>
                <p class="value"><%= guestName %></p>
                <p style="font-size: 13px; color: var(--text-muted);">ID: <%= transactionId %></p>
            </div>
            <div style="text-align: right;">
                <span class="label">Property</span>
                <p class="value"><%= hotelName %></p>
                <p style="font-size: 13px; color: var(--text-muted);"><%= hotelLocation %></p>
            </div>
        </div>

        <div class="stay-summary">
            <div>
                <span class="label">Check-in</span>
                <p class="value"><%= checkIn %></p>
            </div>
            <div>
                <span class="label">Check-out</span>
                <p class="value"><%= checkOut %></p>
            </div>
            <div>
                <span class="label">Nights</span>
                <p class="value"><%= nights %></p>
            </div>
            <div style="text-align: right;">
                <span class="label">Room</span>
                <p class="value"><%= roomType %></p>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Description</th>
                    <th class="text-center">Qty</th>
                    <th class="text-right">Rate</th>
                    <th class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <p style="font-weight: 700; margin-bottom: 4px;">Accommodation</p>
                        <p style="font-size: 12px; color: var(--text-muted);">Stay for <%= nights %> night(s)</p>
                    </td>
                    <td class="text-center"><%= nights %></td>
                    <td class="text-right">$<%= ratePerNight.toFixed(2) %></td>
                    <td class="text-right">$<%= (nights * ratePerNight).toFixed(2) %></td>
                </tr>
                
            </tbody>
        </table>

        <div class="totals-container">
            <div class="totals-table">
                <div class="total-row">
                    <span style="color: var(--text-muted);">Subtotal</span>
                    <span>$<%= (nights * ratePerNight + taxes).toFixed(2) %></span>
                </div>
                <% if (discount > 0) { %>
                <div class="total-row" style="color: #166534;">
                    <span>Discount</span>
                    <span>-$<%= discount.toFixed(2) %></span>
                </div>
                <% } %>
                <div class="total-row grand-total">
                    <span>Total Paid</span>
                    <span>$<%= totalAmount.toFixed(2) %></span>
                </div>
            </div>
        </div>

        <div class="footer">
            <p style="font-weight: 700; margin-bottom: 5px;">Thank you for your business!</p>
            <p>If you have any questions, please contact support@hotelbook.com</p>
            <p style="margin-top: 15px; font-style: italic;">HotelBook Inc. | 2026</p>
        </div>
    </div>
</div>

</body>
</html>